# ==========================================
# SHARED MONOREPO ENVIRONMENT VARIABLES
# Variables used across multiple apps/packages
# Copy to .env (committed) or .env.local (gitignored)
# ==========================================

# Database (shared by all apps)
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="main"
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}"

# Redis (optional, for caching/sessions)
REDIS_URL="redis://localhost:6379"

# External APIs (shared services)
# OpenAI
OPENAI_API_KEY="sk-..."

# AWS
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# Supabase
SUPABASE_URL="https://project.supabase.co"
SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# Email Service (shared)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""

# Monitoring (optional)
SENTRY_DSN=""

# General
NODE_ENV="development"
LOG_LEVEL="info"

# API Service
API_PORT="4000"

# Web Service
WEB_PORT="3000"
NEXT_PUBLIC_API_URL="http://localhost:4000"
