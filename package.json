{
  "name": "turborepo-template",
  "private": true,
  "type": "module",
  "scripts": {
    "preinstall": "pnpm dlx only-allow pnpm",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,js,mjs}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,js,mjs}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:coverage": "turbo run test:coverage",
    "ver:bump": "./scripts/versioning/version-bump.sh",
    "ver:bump-main": "./scripts/versioning/bump-main-version.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "9",
    "eslint": "9",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "turbo": "^2.9.17",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "version": "0.0.1"
}
