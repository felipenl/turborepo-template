# ==========================================
# ENVIRONMENT VARIABLES TEMPLATE
# ==========================================
#
# Copy this file to .env.{NODE_ENV}:
#   - .env.local       (for local development, default when NODE_ENV not set)
#   - .env.development (for staging/dev server)
#   - .env.production  (for production deployment)
#   - .env.test        (for testing)
#
# The correct file is loaded automatically based on NODE_ENV
# ==========================================

# ==========================================
# DOMAINS (Production)
# ==========================================
# Update these with your actual domains
API_DOMAIN="api.example.com"
WEB_DOMAIN="example.com"

# ==========================================
# TRAEFIK / SSL (Optional)
# ==========================================
# Only needed if using DNS challenge (Cloudflare)
# Uncomment if you switch from HTTP to DNS challenge in traefik.yml
# CF_API_EMAIL="your-email@example.com"
# CF_DNS_API_TOKEN="your-cloudflare-api-token"

# ==========================================
# DATABASE
# ==========================================
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="change-me-in-production"
POSTGRES_DB="monorepo"
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}"

# Redis (optional, for caching/sessions)
REDIS_URL="redis://localhost:6379"

# External APIs (shared services)
# OpenAI
OPENAI_API_KEY="sk-..."

# AWS
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# Supabase
SUPABASE_URL="https://project.supabase.co"
SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# Email Service (shared)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""

# Monitoring (optional)
SENTRY_DSN=""

# ==========================================
# GENERAL
# ==========================================
NODE_ENV="production"
LOG_LEVEL="info"

# ==========================================
# SERVICES
# ==========================================
# API Service
API_PORT="4000"

# Web Service
WEB_PORT="3000"
NEXT_PUBLIC_API_URL="https://${API_DOMAIN}"
