#!/usr/bin/env sh

# This hook runs after a successful merge
# We only want to bump versions when merging into master/main

# The first argument is 1 if the merge was a squash merge, 0 otherwise
SQUASH_MERGE=$1

# Get the current branch
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)

# Check if we're on master or main
if [ "$CURRENT_BRANCH" = "master" ] || [ "$CURRENT_BRANCH" = "main" ]; then
    echo "🔄 Post-merge on $CURRENT_BRANCH detected, running version bump..."
    
    # Run the version bump
    if node packages/version-bump/cli.js; then
        # Check if there are any staged changes from the version bump
        if ! git diff --cached --quiet; then
            echo "📦 Version bump created staged changes, creating additional commit..."
            git commit -m "chore: version bump after merge to $CURRENT_BRANCH [skip ci]"
        elif ! git diff --quiet; then
            echo "📦 Version bump created unstaged changes, staging and committing..."
            git add .
            git commit -m "chore: version bump after merge to $CURRENT_BRANCH [skip ci]"
        else
            echo "✅ No version changes needed"
        fi
    else
        echo "⚠️  Version bump failed, skipping commit"
    fi
else
    echo "ℹ️  Merge completed on $CURRENT_BRANCH (not master/main), skipping version bump"
fi