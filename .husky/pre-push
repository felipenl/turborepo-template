#!/usr/bin/env sh

CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)

if [ "$CURRENT_BRANCH" = "master" ] || [ "$CURRENT_BRANCH" = "main" ]; then
    echo "🔄 Pre-push on $CURRENT_BRANCH detected"
    ./scripts/versioning/version-bump.sh "" "" --commit
else
    echo "ℹ️  Skipping version bump (not on main/master)"
fi
